# Copy this file to .env and fill in your values
# (For VPS: used by docker-compose. For others: set these as environment variables in the dashboard)

API_ID=               # Your Telegram API ID (from my.telegram.org)
API_HASH=             # Your Telegram API Hash (from my.telegram.org)
BOT_TOKEN=            # Your bot token (from @BotFather)
BOT_USERNAME=         # Your bot's username WITHOUT @ (e.g. myencodebot)

BASE=                 # Chat ID of your log/base group (e.g. -1001234567890)
FFMPEG=               # Chat ID of the channel where FFmpeg executables are stored
FFMPEGID=             # Space-separated message IDs of FFmpeg executables (e.g. "2 3 4")
FFMPEGCMD=            # Message ID of the FFmpeg command message (e.g. 5)
DESTINATION=          # Chat ID of the channel/group to send encoded output files

HEROKU_API_KEY=       # Your Heroku API key (only needed if using /restart command)
HEROKU_APP_NAME=      # Your Heroku app name (only needed if using /restart command)
